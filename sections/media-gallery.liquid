{{ 'media-gallery.css' | asset_url | stylesheet_tag }}
{% if section.settings.revert_view == true %}
  {% style %}
    .left__column {
      order: 2;
    }
    .right__column {
      order: 1;
    }
  {% endstyle %}
{% endif %}
<section class="page-width container media__gallery">
  {% if section.settings.title != blank %}
    <h2 class="title">{{ section.settings.title }}</h2>
  {% endif %}
  {% if section.settings.description != blank %}
    <h4 class="description">{{ section.settings.description }}</h4>
  {% endif %}
  <div class="gallery">
    <div class="left__column">
      {% for block in section.blocks %}
        {% if block.type == 'image' %}
          <div class="image__box">
            <img src="{{ block.settings.image |  image_url: width: 500 }}" alt="">
            <div class="content_box" style="text-align: {{ block.settings.desktop_content_alignment }};">
              {% if block.settings.title != blank %}
                <span class="image__title">{{ block.settings.title }}</span>
              {% endif %}
              {% if block.settings.description != blank %}
                <span class="image__desc">{{ block.settings.description }}</span>
              {% endif %}
              <div class="gallery__cta-wrapper">
                <a
                  {% if block.settings.button_url == blank %}
                    role="link" aria-disabled="true"
                  {% else %}
                    href="{{ block.settings.button_url }}"
                  {% endif %}
                  class="button{% if block.settings.button_style_secondary %} button--secondary{% else %} button--primary{% endif %}"
                  {{ block.shopify_attributes }}
                >
                  {{ block.settings.button_text | escape }}
                </a>
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
    <div class="right__column">
      <div class="image__box large">
        <img src="{{ section.settings.main_image |  image_url: width: 500 }}" alt="">
      </div>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "t:sections.names.media_gallery",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.media_gallery.settings.header"
    },
    {
      "type": "text",
      "id": "title",
      "label": "t:sections.media_gallery.settings.title"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:sections.media_gallery.settings.description"
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "t:sections.media_gallery.settings.main_image"
    },
    {
      "type": "checkbox",
      "id": "revert_view",
      "label": "t:sections.media_gallery.settings.revert_view",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "t:sections.media_gallery.blocks.image.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.media_gallery.blocks.image.label"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.media_gallery.blocks.image.title"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "t:sections.media_gallery.blocks.image.description"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "t:sections.media_gallery.blocks.image.btn_label"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "t:sections.media_gallery.blocks.image.btn_url"
        },
        {
          "type": "color",
          "id": "background_color",
          "label": "t:sections.media_gallery.blocks.image.btn_bg"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "t:sections.media_gallery.blocks.image.btn_text_color"
        },
        {
          "type": "checkbox",
          "id": "button_style_secondary",
          "default": false,
          "label": "t:sections.image-with-text.blocks.button.settings.outline_button.label"
        },
        {
          "type": "select",
          "id": "desktop_content_alignment",
          "options": [
            {
              "value": "left",
              "label": "Left"
            },
            {
              "value": "center",
              "label": "Center"
            },
            {
              "value": "right",
              "label": "Right"
            }
          ],
          "default": "center",
          "label": "Content Alignment"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.names.media_gallery",
      "category": "Media Gallery"
    }
  ]
}
{% endschema %}
