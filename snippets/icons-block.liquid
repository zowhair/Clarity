<style>
  .clarity-section__block-id-{{ block.id }} .clarity-section__icons {
    --flex-gap: {{ block.settings.gap }}px;
    gap: var(--flex-gap);
    flex-wrap: wrap;
    margin: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px 0;
  }

  .clarity-section__block-id-{{ block.id }} .clarity-section__Icon {
    --flex-items: {{ 100.00 | divided_by: block.settings.icon_width }};
    text-align: center;
    flex: 0 1 calc((100% / var(--flex-items)) - (((var(--flex-items) - 1) / var(--flex-items)) * var(--flex-gap)));
    width: calc((100% / var(--flex-items)) - (((var(--flex-items) - 1) / var(--flex-items)) * var(--flex-gap)));
  }

  .clarity-section__block-id-{{ block.id }} .clarity-section__image__wrapper {
    position: relative;
    width: {{ block.settings.image_size }}px;
    height: auto;
    display: inline-block;
    font-size: 0;
  }
  .clarity-section__block-id-{{ block.id }} .clarity-section__image__wrapper img,
  .clarity-section__block-id-{{ block.id }} .clarity-section__image__wrapper svg {
    position: relative;
    width: 100%;
    height: auto;
  }

  .clarity-section__block-id-{{ block.id }} svg.clarity-section__svg-sizer {
    width: 100%;
  }

  .clarity-section__block-id-{{ block.id }} .clarity-section__small-heading + .clarity-section__icon-text {
    margin-top: 5px;
  }

  .clarity-section__block-id-{{ block.id }} .clarity-section__Icon a,
  .clarity-section__block-id-{{ block.id }} .clarity-section__Icon p {
    color: {{ section.settings.text_color }};
    line-height: 1.2;
    margin: 0;
    text-decoration: none;
  }

  {%- if block.settings.icon_layout == 'left' -%}
    .clarity-section__block-id-{{ block.id }} .clarity-section__Icon {
      display: flex;
      flex-direction: row;
      align-items: center;
      gap: 15px;
    }

    .clarity-section__block-id-{{ block.id }} .clarity-section__image__wrapper {
      flex: 0 0 {{block.settings.image_size }}px;
      max-width: {{block.settings.image_size }}px;
    }

    .clarity-section__block-id-{{ block.id }} .clarity-section__icon-content {
      flex: 1 1 auto;
      text-align: left;
    }
    .clarity-section__icon-heading {
      margin: 0;
     }

  {%- elsif block.settings.icon_layout == 'top' -%}
    .clarity-section__block-id-{{ block.id }} .clarity-section__Icon {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 5px;
      justify-content: flex-start;
    }

    .clarity-section__block-id-{{ block.id }} .clarity-section__icon-content {
      text-align: center;
    }
     .clarity-section__icon-heading {
      margin-bottom: 0;
      margin-top: 1rem;
     }

  {%- endif -%}


  @media (max-width: 767px) {
    .clarity-section__block-id-{{ block.id }} .clarity-section__Icon {
      --flex-items: {{ 100.00 | divided_by: block.settings.mobile_icon_width }};
    }
    .clarity-section__block-id-{{ block.id }} .clarity-section__image__wrapper {
    width: {{ block.settings.mobile_image_width }}px;
  }

    {%- if block.settings.mobile_icon_layout == 'left' -%}
      .clarity-section__block-id-{{ block.id }} .clarity-section__Icon {
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 15px;
      }
      .clarity-section__block-id-{{ block.id }} .clarity-section__image__wrapper {
        flex: 0 0 {{block.settings.mobile_image_width }}px;
        max-width: {{block.settings.mobile_image_width }}px;
      }

      .clarity-section__block-id-{{ block.id }} .clarity-section__icon-content {
        flex: 1 1 auto;
        text-align: left;
      }

    {%- elsif block.settings.mobile_icon_layout == 'top' -%}
      .clarity-section__block-id-{{ block.id }} .clarity-section__Icon {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 5px;
      }
       .clarity-section__block-id-{{ block.id }} .clarity-section__image__wrapper {
        max-width: {{block.settings.mobile_image_width }}px;
      }

      .clarity-section__block-id-{{ block.id }} .clarity-section__icon-content {
        text-align: center;
      }

    {%- endif -%}
  }
</style>
<div class="clarity-section__flex clarity-section__icons clarity-section__justify-{{ block.settings.icon_alignment }}">
  {%- for index in (1..6) -%}
    {%- capture icon -%}icon_{{ forloop.index }}{%- endcapture -%}
    {%- capture icon_old -%}icon_old_{{ forloop.index }}{%- endcapture -%}
    {%- capture heading -%}heading_{{ forloop.index }}{%- endcapture -%}
    {%- capture text -%}text_{{ forloop.index }}{%- endcapture -%}
    {%- capture link -%}link_{{ forloop.index }}{%- endcapture -%}
    {%- if block.settings[icon] != blank or block.settings[icon_old] != 'none' -%}
      <div class="clarity-section__flex-item clarity-section__Icon clarity-section__rte">
        <a
          {% if block.settings[link] != blank %}
            href="{{ block.settings[link] }}"
          {% endif %}
          class="clarity-section__block-id-{{ block.id }} clarity-section__image__wrapper"
        >
          {% comment %}
            <svg
              class="clarity-section__block-id-{{ block.id }} clarity-section__svg-sizer"
              viewBox="0 0 {{ block.settings[icon].width }} {{ block.settings[icon].height }}"
            ></svg>
          {% endcomment %}

          {%- capture sizes -%}
                              (max-width: 480px) calc(100vw / {{ block.settings.icon_width }}), calc({{ section.settings.text_width | default: 50 }}vw / {{ block.settings.icon_width }})
                            {%- endcapture -%}
          {%- if block.settings[icon] == blank -%}
            {%-
              render 'icon-accordion', icon: block.settings.[icon_old], | image_url: width: block.settings[icon].width
              | image_tag: widths: widths, sizes: sizes
            -%}
          {% else %}
            {{
              block.settings[icon]
              | image_url: width: block.settings[icon].width
              | image_tag: widths: widths, sizes: sizes
            }}
          {% endif %}
        </a>
        {%- if block.settings[heading] != blank or block.settings[text] != blank -%}
          <div class="clarity-section__icon-content">
            {%- if block.settings[heading] != blank -%}
              <h4 class="clarity-section__icon-heading clarity-section__small-heading">
                {%- if block.settings[link] != blank -%}
                  <a href="{{ block.settings[link] }}">
                {%- endif -%}
                {{ block.settings[heading] }}
                {%- if block.settings[link] != blank -%}
                  </a>
                {%- endif -%}
              </h4>
            {%- endif -%}
            {%- if block.settings[text] != blank -%}
              <p class="clarity-section__icon-text clarity-section__rte">
                {{ block.settings[text] }}
              </p>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}
  {%- endfor -%}
</div>
