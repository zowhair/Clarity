<style>
  {%- assign button_alpha = block.settings.button_background_color | color_extract: 'alpha' -%}

  .clarity-section__block-id-{{ block.id }} .clarity-section__form {
    --form-gap: 5px;
    width: 100%;
    display: flex;
    flex-wrap: wrap;
    gap: calc(var(--form-gap) * 2);
  }

  .clarity-section__block-id-{{ block.id }} .clarity-section__form-text {
    color: inherit;
    font-size: 1.5rem;
  }

  .clarity-section__block-id-{{ block.id }} .clarity-section__form input {
    margin: unset;
    padding: 0.8em;
    font-size: 1.5rem;
  }

  .clarity-section__block-id-{{ block.id }} .clarity-section__form input[type="text"],
  .clarity-section__block-id-{{ block.id }} .clarity-section__form input[type="email"] {
    padding: 0.8em;
    background: transparent;
    border: thin solid rgba(var(--color-foreground));
    color: rgba(var(--color-foreground));
  }

  .clarity-section__form--{{ block.id }} input {
    width: 100%;
  }

  {%- if block.settings.show_first_name and block.settings.show_last_name -%}
    .clarity-section__form--{{ block.id }}-compact .clarity-section__newsletter_first-name,
    .clarity-section__form--{{ block.id }}-compact .clarity-section__newsletter_last-name {
      width: calc(50% - var(--form-gap));
    }
  {%- endif -%}

  .clarity-section__form--{{ block.id }}-compact .clarity-section__newsletter_email {
    width: calc(70% - var(--form-gap));
  }

  .clarity-section__form--{{ block.id }}-compact .clarity-section__button {
    width: calc(30% - var(--form-gap));
  }

  .clarity-section__block-id-{{ block.id }} input::placeholder {
    opacity: 0.6;
    color: rgba(var(--color-foreground));
  }

  .clarity-section__block-id-{{ block.id }} .clarity-section__button {
    justify-content: center;
    text-align: center;
    transition: all 0.3s ease-in-out;
    border: thin solid;
    border-radius: {{ block.settings.button_radius }}px;
    color: {{ block.settings.button_label_color }};
    font-size: 16px;
    border-color: {%- if button_alpha != 0 -%}{{ block.settings.button_background_color }}{%- else -%}{{ block.settings.button_label_color }}{%- endif -%};
    background-color: {{ block.settings.button_background_color }};
  }

  .clarity-section__block-id-{{ block.id }} .clarity-section__button:hover {
    opacity: 1;
    {%- if button_alpha != 0 -%}
    background-color: {{ block.settings.button_background_color | color_darken: 10 }};
    border-color: transparent;
    {%- else -%}
    background-color: {{ block.settings.button_label_color | color_modify: 'alpha', 0.1 }}
    {%- endif -%};
  }
</style>
{%- capture form_id -%}clarity-section__form-{{ section_id }}{%- endcapture -%}
{%- form 'customer', id: form_id -%}
  {%- comment -%} Error and success messages for submitted form {%- endcomment -%}
  <div class="clarity-section__form-response clarity-section__text">
    {%- if form.posted_successfully? -%}
      <p class="clarity-section__form-reply--success">
        {% render 'icon-success' -%}
        {{- 'newsletter.success' | t }}
      </p>
    {%- elsif form.errors -%}
      {%- for field in form.errors -%}
        <p class="clarity-section__form-reply--error">{{ field }} - {{ form.errors.messages[field] }}</p>
      {%- endfor -%}
    {%- endif -%}
  </div>

  {%- comment -%} Hidden newsletter fields {%- endcomment -%}
  <input type="hidden" name="contact[tags]" value="newsletter">
  <input type="hidden" name="challenge" value="false">

  <div class="clarity-section__block-id-{{ block.id }} clarity-section__form clarity-section__form--{{ block.id }} clarity-section__form--{{ block.id }}-{{ block.settings.layout }}">
    {%- if block.settings.show_first_name -%}
      <label class="clarity-section__visually-hidden visually-hidden" for="first-name-{{ block.id }}">
        {{- block.settings.first_name_label -}}
      </label>
      <input
        class="clarity-section__newsletter_first-name"
        type="text"
        name="contact[first_name]"
        id="first-name-{{ block.id }}"
        placeholder="{{ block.settings.first_name_label }}"
      >
    {%- endif -%}
    {%- if block.settings.show_last_name -%}
      <label class="clarity-section__visually-hidden visually-hidden" for="last-name-{{ block.id }}">
        {{- block.settings.last_name_label -}}
      </label>
      <input
        class="clarity-section__newsletter_last-name"
        type="text"
        name="contact[last_name]"
        id="last-name-{{ block.id }}"
        placeholder="{{ block.settings.last_name_label }}"
      >
    {%- endif -%}
    <label class="clarity-section__visually-hidden visually-hidden" for="email-{{ block.id }}">
      {{- block.settings.email_label -}}
    </label>
    <input
      class="clarity-section__newsletter_email"
      type="email"
      name="contact[email]"
      required
      id="email-{{ block.id }}"
      placeholder="{{ block.settings.email_label }}"
    >
    <input class="clarity-section__button" type="submit" value="{{ block.settings.submit_label }}">
  </div>
{%- endform -%}
